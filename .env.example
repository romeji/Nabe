# ===========================================
# BASE DE DONNEES (Neon - https://neon.tech)
# ===========================================
# Crée un compte gratuit sur neon.tech, crée un projet "nabe"
# Copie la "Connection string" (pooled) ici :
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ===========================================
# NEXTAUTH (authentification admin)
# ===========================================
# Génère un secret avec : openssl rand -base64 32
NEXTAUTH_SECRET="remplace-moi-par-un-secret-aleatoire"
NEXTAUTH_URL="http://localhost:3000"

# Identifiants du compte admin (utilisés par le script de seed)
ADMIN_EMAIL="toi@nabe-bijoux.fr"
ADMIN_PASSWORD="change-moi-mot-de-passe-fort"

# ===========================================
# CLOUDINARY (stockage images produits)
# ===========================================
# Crée un compte gratuit sur cloudinary.com -> Dashboard
CLOUDINARY_CLOUD_NAME="ton-cloud-name"
CLOUDINARY_API_KEY="ta-cle-api"
CLOUDINARY_API_SECRET="ton-secret-api"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="ton-cloud-name"

# ===========================================
# STRIPE (paiement en ligne)
# ===========================================
# Récupère ces clés sur dashboard.stripe.com (mode test puis production)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# URL publique du site (pour les redirections Stripe et emails)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
