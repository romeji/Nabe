// Schéma de la base de données Nabe Bijoux
// Documentation : https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ADMINISTRATION
// ============================================================

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hashé avec bcrypt
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// CATALOGUE
// ============================================================

enum TypeBijou {
  BAGUE
  COLLIER
  BOUCLES_OREILLES
  BRACELET
  PIECE_UNIQUE
  COFFRET_CADEAU
}

enum Matiere {
  OR_JAUNE_18K
  OR_BLANC_18K
  OR_ROSE_18K
  ARGENT_925
  PLAQUE_OR
}

enum Pierre {
  DIAMANT
  PERLE
  PIERRE_DE_LUNE
  QUARTZ
  TOPAZE
  SAPHIR
  EMERAUDE
  AUCUNE
}

enum Disponibilite {
  EN_STOCK
  FABRICATION_SUR_COMMANDE
  PIECE_UNIQUE_DISPO
  EPUISE
}

model Categorie {
  id          String    @id @default(cuid())
  nom         String    @unique
  slug        String    @unique
  description String?
  image       String? // url Cloudinary
  ordre       Int       @default(0)
  produits    Produit[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Produit {
  id              String         @id @default(cuid())
  nom             String
  slug            String         @unique
  description     String
  prix            Decimal        @db.Decimal(10, 2)
  type            TypeBijou
  matiere         Matiere
  pierre          Pierre         @default(AUCUNE)
  couleurPierre   String? // ex: "Blanc", "Champagne", "Rose"
  delaiFabrication String?       // ex: "2 à 3 semaines"
  fabriqueEnFrance Boolean       @default(true)
  tailleSurMesure  Boolean       @default(false)
  taillesDisponibles String[]    @default([]) // ex: ["48","50","52"]
  disponibilite   Disponibilite  @default(EN_STOCK)
  stock           Int            @default(0)
  images          ProduitImage[]
  categorieId     String?
  categorie       Categorie?     @relation(fields: [categorieId], references: [id])
  actif           Boolean        @default(true)
  enAvant         Boolean        @default(false) // mis en avant sur l'accueil
  lignesCommande  LigneCommande[]
  mouvementsStock MouvementStock[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([type])
  @@index([disponibilite])
}

model ProduitImage {
  id        String   @id @default(cuid())
  url       String // url Cloudinary
  publicId  String? // public_id Cloudinary (pour suppression)
  alt       String?
  ordre     Int      @default(0)
  produitId String
  produit   Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============================================================
// STOCK
// ============================================================

enum TypeMouvement {
  ENTREE
  SORTIE
  AJUSTEMENT
  VENTE
}

model MouvementStock {
  id         String        @id @default(cuid())
  produitId  String
  produit    Produit       @relation(fields: [produitId], references: [id], onDelete: Cascade)
  type       TypeMouvement
  quantite   Int // positif ou négatif selon le type
  motif      String?
  createdAt  DateTime      @default(now())
}

// ============================================================
// VENTES / COMMANDES
// ============================================================

enum StatutCommande {
  EN_ATTENTE
  PAYEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
  REMBOURSEE
}

model Commande {
  id                    String          @id @default(cuid())
  numero                String          @unique // ex: NABE-2026-0001
  statut                StatutCommande  @default(EN_ATTENTE)
  clientNom             String
  clientEmail           String
  clientTelephone       String?
  adresseLivraison      String?
  ville                 String?
  codePostal            String?
  pays                  String?         @default("France")
  sousTotal             Decimal         @db.Decimal(10, 2)
  fraisLivraison         Decimal        @db.Decimal(10, 2) @default(0)
  total                 Decimal         @db.Decimal(10, 2)
  stripeSessionId       String?         @unique
  stripePaymentIntentId String?
  lignes                LigneCommande[]
  createdAt             DateTime        @default(now())
  updatedAt              DateTime       @updatedAt
}

model LigneCommande {
  id          String   @id @default(cuid())
  commandeId  String
  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produitId   String?
  produit     Produit? @relation(fields: [produitId], references: [id])
  nomProduit  String // snapshot du nom au moment de la commande
  taille      String?
  prixUnitaire Decimal @db.Decimal(10, 2)
  quantite    Int
}

// ============================================================
// SUR-MESURE
// ============================================================

enum StatutDemandeSurMesure {
  NOUVELLE
  EN_DISCUSSION
  DEVIS_ENVOYE
  ACCEPTEE
  EN_FABRICATION
  TERMINEE
  REFUSEE
}

model DemandeSurMesure {
  id              String                  @id @default(cuid())
  modeleSelectionne String?
  tailleSouhaitee String?
  matiere         String?
  pierre          String?
  gravure         String?
  message         String
  nom             String
  email           String
  telephone       String?
  statut          StatutDemandeSurMesure  @default(NOUVELLE)
  notesAdmin      String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

// ============================================================
// CONTACT
// ============================================================

enum StatutMessage {
  NOUVEAU
  LU
  REPONDU
  ARCHIVE
}

model MessageContact {
  id        String        @id @default(cuid())
  nom       String
  email     String
  sujet     String
  message   String
  statut    StatutMessage @default(NOUVEAU)
  createdAt DateTime      @default(now())
}

// ============================================================
// CONTENU EDITABLE DES PAGES (CMS léger)
// ============================================================

model ContenuPage {
  id        String   @id @default(cuid())
  page      String // ex: "accueil", "maison", "contact"
  cle       String // ex: "hero_titre", "hero_soustitre"
  valeur    String   @db.Text
  type      String   @default("texte") // "texte", "image", "html"
  updatedAt DateTime @updatedAt

  @@unique([page, cle])
}

// ============================================================
// NEWSLETTER
// ============================================================

model AbonneNewsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ============================================================
// TEMOIGNAGES (page Maison)
// ============================================================

model Temoignage {
  id        String   @id @default(cuid())
  auteur    String
  texte     String
  note      Int      @default(5)
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}
