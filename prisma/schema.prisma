// Schéma de la base de données Nabe Bijoux
// Documentation : https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ADMINISTRATION
// ============================================================

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hashé avec bcrypt
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// COMPTES CLIENTS (différents du compte Admin)
// ============================================================
// Modèles imposés par l'adapter NextAuth/Prisma pour supporter
// à la fois email+mot de passe (Credentials) et Google OAuth.

model Client {
  id              String    @id @default(cuid())
  nom             String?
  email           String    @unique
  emailVerifie    DateTime?
  password        String? // null si connecté uniquement via Google
  image           String?
  telephone       String?
  stripeCustomerId String?  @unique // référence Stripe Customer (jamais de numéro de carte stocké ici)
  comptes         CompteOAuth[]
  favoris         Favori[]
  commandes       Commande[]
  adresses        AdressePostale[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdressePostale {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  libelle      String? // ex: "Domicile", "Travail"
  destinataire String // nom complet du destinataire
  ligne1       String
  ligne2       String?
  ville        String
  codePostal   String
  pays         String   @default("France")
  telephone    String?
  parDefaut    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompteOAuth {
  id                String  @id @default(cuid())
  clientId          String
  client            Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model SessionClient {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  clientId     String
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favori {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  produitId String
  produit   Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([clientId, produitId])
}

// ============================================================
// CATALOGUE
// ============================================================

enum TypeBijou {
  BAGUE
  COLLIER
  BOUCLES_OREILLES
  BRACELET
  PIECE_UNIQUE
  COFFRET_CADEAU
}

enum Disponibilite {
  EN_STOCK
  FABRICATION_SUR_COMMANDE
  CREATION_SUR_MESURE
  PIECE_UNIQUE_DISPO
  EPUISE
}

model Categorie {
  id          String    @id @default(cuid())
  nom         String    @unique
  slug        String    @unique
  description String?
  image       String? // url Cloudinary
  ordre       Int       @default(0)
  produits    Produit[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Matiere {
  id        String    @id @default(cuid())
  nom       String    @unique // ex: "Or jaune 18 carats", "Argent 925"
  slug      String    @unique
  ordre     Int       @default(0)
  produits  Produit[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CouleurPierre {
  id         String    @id @default(cuid())
  nom        String    @unique
  codeHex    String
  ordre      Int       @default(0)
  pierres    PierreCouleur[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Pierre {
  id          String              @id @default(cuid())
  nom         String              @unique
  slug        String              @unique
  description String?             @db.Text
  ordre       Int                 @default(0)
  couleurs    PierreCouleur[]
  produits    ProduitPierre[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// Table de liaison Pierre <-> CouleurPierre (many-to-many)
model PierreCouleur {
  id            String        @id @default(cuid())
  pierreId      String
  pierre        Pierre        @relation(fields: [pierreId], references: [id], onDelete: Cascade)
  couleurPierreId String
  couleurPierre CouleurPierre @relation(fields: [couleurPierreId], references: [id], onDelete: Cascade)

  @@unique([pierreId, couleurPierreId])
}

// Table de liaison Produit <-> Pierre (un bijou peut avoir plusieurs pierres)
model ProduitPierre {
  id        String  @id @default(cuid())
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)
  pierreId  String
  pierre    Pierre  @relation(fields: [pierreId], references: [id], onDelete: Cascade)

  @@unique([produitId, pierreId])
}

model Collection {
  id          String    @id @default(cuid())
  nom         String    @unique
  slug        String    @unique
  description String?
  image       String? // url Cloudinary
  ordre       Int       @default(0)
  actif       Boolean   @default(true)
  produits    Produit[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Produit {
  id              String         @id @default(cuid())
  reference       String         @unique // ex: NABE-BAG-2026-0001, généré automatiquement à la création
  nom             String
  slug            String         @unique
  description     String
  prix            Decimal        @db.Decimal(10, 2)
  type            TypeBijou
  matiereId       String?
  matiere         Matiere?       @relation(fields: [matiereId], references: [id])
  pierres         ProduitPierre[]
  delaiFabrication String?       // ex: "2 à 3 semaines"
  fabriqueEnFrance Boolean       @default(true)
  tailleSurMesure  Boolean       @default(false)
  taillesDisponibles String[]    @default([]) // ex: ["48","50","52"]
  disponibilite   Disponibilite  @default(EN_STOCK)
  stock           Int            @default(0) // stock global (somme des stockTailles si tailles définies, sinon valeur libre)
  stockTailles    StockTaille[]  // stock détaillé par taille (utilisé seulement si taillesDisponibles est rempli)
  images          ProduitImage[]
  categorieId     String?
  categorie       Categorie?     @relation(fields: [categorieId], references: [id])
  collectionId    String?
  collection      Collection?    @relation(fields: [collectionId], references: [id])
  actif           Boolean        @default(true)
  enAvant         Boolean        @default(false) // mis en avant sur l'accueil (carrousel "sélection")
  composerAvecActif Boolean      @default(true) // affiche ou non le bloc "À composer avec" sur ce produit
  prixPromo       Decimal?       @db.Decimal(10, 2) // prix réduit affiché à la place de prix si renseigné et actif
  promoActive     Boolean        @default(false) // active/désactive la promo sans effacer le prixPromo saisi
  promoDebut      DateTime?      // optionnel : la promo ne s'affiche qu'à partir de cette date
  promoFin        DateTime?      // optionnel : la promo ne s'affiche plus après cette date
  nombreVentes    Int            @default(0) // incrémenté à chaque vente, utile pour les critères de recommandation
  favoris         Favori[]
  lignesCommande  LigneCommande[]
  mouvementsStock MouvementStock[]
  // "À composer avec" — jusqu'à 2 bijoux suggérés, choisis manuellement par produit.
  // composeAvec : les bijoux que CE produit suggère.
  // suggerePar : les produits qui suggèrent CE produit (relation inverse, non utilisée à l'affichage).
  composeAvec     ComposerAvec[]  @relation("ProduitSource")
  suggerePar      ComposerAvec[]  @relation("ProduitSuggere")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([type])
  @@index([disponibilite])
}

// Table de liaison pour le bloc "À composer avec" (2 suggestions maximum par produit,
// définies manuellement depuis l'admin). Activable/désactivable par produit.
model ComposerAvec {
  id              String  @id @default(cuid())
  produitSourceId String
  produitSource   Produit @relation("ProduitSource", fields: [produitSourceId], references: [id], onDelete: Cascade)
  produitSuggereId String
  produitSuggere  Produit @relation("ProduitSuggere", fields: [produitSuggereId], references: [id], onDelete: Cascade)
  ordre           Int     @default(0)

  @@unique([produitSourceId, produitSuggereId])
}

model ProduitImage {
  id        String   @id @default(cuid())
  url       String // url Cloudinary
  publicId  String? // public_id Cloudinary (pour suppression)
  alt       String?
  ordre     Int      @default(0)
  produitId String
  produit   Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============================================================
// STOCK
// ============================================================

enum TypeMouvement {
  ENTREE
  SORTIE
  AJUSTEMENT
  VENTE
}

model MouvementStock {
  id         String        @id @default(cuid())
  produitId  String
  produit    Produit       @relation(fields: [produitId], references: [id], onDelete: Cascade)
  type       TypeMouvement
  quantite   Int // positif ou négatif selon le type
  motif      String?
  createdAt  DateTime      @default(now())
}

// Stock détaillé par taille (ex: Bague taille 52 -> 3 en stock, taille 54 -> 0).
// N'est utilisé que pour les produits qui ont des taillesDisponibles renseignées.
model StockTaille {
  id        String  @id @default(cuid())
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)
  taille    String
  quantite  Int     @default(0)

  @@unique([produitId, taille])
}

// ============================================================
// CODES DE REDUCTION
// ============================================================

enum TypeReduction {
  POURCENTAGE
  MONTANT_FIXE
}

model CodeReduction {
  id              String          @id @default(cuid())
  code            String          @unique // ex: "BIENVENUE10"
  type            TypeReduction   @default(POURCENTAGE)
  valeur          Decimal         @db.Decimal(10, 2) // ex: 10 (pour 10%) ou 15.00 (pour 15€)
  actif           Boolean         @default(true)
  // Pour une future rémunération de collaborateurs/affiliés sur ce code :
  nomCollaborateur String?
  commissionPourcentage Decimal?  @db.Decimal(5, 2) // ex: 10.00 = 10% du montant de la commande reversé
  dateExpiration  DateTime?
  utilisationMax  Int? // null = illimité
  montantMinimum  Decimal?        @db.Decimal(10, 2) // panier minimum requis pour appliquer le code
  commandes       Commande[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ============================================================
// VENTES / COMMANDES
// ============================================================

enum StatutCommande {
  EN_ATTENTE
  PAYEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
  REMBOURSEE
}

model Commande {
  id                    String          @id @default(cuid())
  numero                String          @unique // ex: NABE-2026-0001
  statut                StatutCommande  @default(EN_ATTENTE)
  clientId              String?
  client                Client?         @relation(fields: [clientId], references: [id])
  clientNom             String
  clientEmail           String
  clientTelephone       String?
  adresseLivraison      String?
  ville                 String?
  codePostal            String?
  pays                  String?         @default("France")
  codeReductionId       String?
  codeReduction         CodeReduction?  @relation(fields: [codeReductionId], references: [id])
  montantReduction      Decimal         @db.Decimal(10, 2) @default(0)
  sousTotal             Decimal         @db.Decimal(10, 2)
  fraisLivraison         Decimal        @db.Decimal(10, 2) @default(0)
  total                 Decimal         @db.Decimal(10, 2)
  stripeSessionId       String?         @unique
  stripePaymentIntentId String?         @unique
  lignes                LigneCommande[]
  createdAt             DateTime        @default(now())
  updatedAt              DateTime       @updatedAt
}

model LigneCommande {
  id          String   @id @default(cuid())
  commandeId  String
  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produitId   String?
  produit     Produit? @relation(fields: [produitId], references: [id])
  nomProduit  String // snapshot du nom au moment de la commande
  taille      String?
  prixUnitaire Decimal @db.Decimal(10, 2)
  quantite    Int
}

// ============================================================
// SUR-MESURE
// ============================================================

enum StatutDemandeSurMesure {
  NOUVELLE
  EN_DISCUSSION
  DEVIS_ENVOYE
  ACCEPTEE
  EN_FABRICATION
  TERMINEE
  REFUSEE
}

model DemandeSurMesure {
  id              String                  @id @default(cuid())
  modeleSelectionne String?
  tailleSouhaitee String?
  matiere         String?
  pierre          String?
  gravure         String?
  message         String
  nom             String
  email           String
  telephone       String?
  statut          StatutDemandeSurMesure  @default(NOUVELLE)
  notesAdmin      String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

// ============================================================
// CONTACT
// ============================================================

enum StatutMessage {
  NOUVEAU
  LU
  REPONDU
  ARCHIVE
}

model MessageContact {
  id        String        @id @default(cuid())
  nom       String
  email     String
  sujet     String
  message   String
  statut    StatutMessage @default(NOUVEAU)
  createdAt DateTime      @default(now())
}

// ============================================================
// CONTENU EDITABLE DES PAGES (CMS léger)
// ============================================================

model ContenuPage {
  id        String   @id @default(cuid())
  page      String // ex: "accueil", "maison", "contact"
  cle       String // ex: "hero_titre", "hero_soustitre"
  valeur    String   @db.Text
  type      String   @default("texte") // "texte", "image", "html"
  updatedAt DateTime @updatedAt

  @@unique([page, cle])
}

// ============================================================
// NEWSLETTER
// ============================================================

model AbonneNewsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum StatutNewsletter {
  BROUILLON
  ENVOYEE
}

model Newsletter {
  id              String           @id @default(cuid())
  sujet           String
  contenu         String           @db.Text // texte de l'email (paragraphes séparés par des retours à la ligne)
  statut          StatutNewsletter @default(BROUILLON)
  nombreDestinataires Int          @default(0)
  envoyeeLe       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// ============================================================
// REGLAGES DU SITE (toggles et configurations diverses)
// ============================================================
// Stockage clé/valeur générique pour tout réglage simple piloté
// depuis l'admin : activer/désactiver un carrousel, configurer le
// pourcentage de la popup de bienvenue, etc.

model ConfigSite {
  cle       String   @id // ex: "carrousel_bestseller_actif", "popup_bienvenue_pourcentage"
  valeur    String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================================
// TEMOIGNAGES (page Maison)
// ============================================================

model Temoignage {
  id        String   @id @default(cuid())
  auteur    String
  texte     String
  note      Int      @default(5)
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ============================================================
// CONTENU POLITIQUES (popups Contact, Entretien, Livraison)
// ============================================================

// Chaque popup editable depuis l'admin : cle = identifiant unique
// ex: "contact-appeler", "contact-ecrire", "entretien-intro",
//     "livraison-intro", "livraison-retours", "livraison-paiement"
model ContenuPolitique {
  cle       String   @id
  titre     String
  contenu   String   @db.Text
  ordre     Int      @default(0)
  updatedAt DateTime @updatedAt
}
